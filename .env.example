# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to Git — it contains secrets!

# Server
PORT=3000
NODE_ENV=development
ADMIN_USER=admin@example.com
ADMIN_PASSWORD=your-secure-password        # dev only — use ADMIN_PASSWORD_HASH in production
ADMIN_PASSWORD_HASH=                       # bcrypt hash — REQUIRED in production
SESSION_SECRET=your-session-secret         # REQUIRED in production
JWT_SECRET=your-jwt-secret                 # REQUIRED in production
API_KEY=your-api-key                       # REQUIRED — protects /portal/invite
APP_URL=http://localhost:3000

# Database (PostgreSQL)
# Local example: postgresql://postgres:postgres@localhost:5432/mayemou_propman
# Render example: postgresql://user:password@host.postgres.render.com:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/mayemou_propman

# Gmail SMTP (for sending invoices and notifications)
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# Node.js / SSL
NODE_TLS_REJECT_UNAUTHORIZED=1
